# Gemini API Key (Obtain from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model name supporting Live API bidirectional stream
GEMINI_MODEL=gemini-2.5-flash-native-audio-latest

# Local WebSocket Port
PORT=8765

# Microphone digital gain boost
MIC_DIGITAL_GAIN=1.0

# Picovoice Porcupine Access Key (get free from console.picovoice.ai)
# Wake word "Jarvis" is built-in — no .ppn file needed!
# Leave empty to disable wake word and use PTT button only.
PICOVOICE_KEY=

# --- Multi-Model: Reasoning (mimo-v2.5-pro) ---
REASONING_API_URL=https://token-plan-sgp.xiaomimimo.com/anthropic
REASONING_API_KEY=your_reasoning_api_key_here
REASONING_MODEL=mimo-v2.5-pro

# --- Camera ---
CAMERA_DEVICE=0
